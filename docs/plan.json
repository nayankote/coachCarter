  "weeks": [
    {
      "week": 1,
      "label": "Base Build",
      "sessions": [
        {
          "id": "mon_bike",
          "day": "Monday",
          "sport": "bike",
          "type": "intervals",
          "duration_min": 60,
          "targets": {
            "power_min": 171,
            "power_max": 181,
            "vi_max": 1.05,
            "tss_target": 75,
            "warmup": "10min easy spin 105-115W",
            "main_set": "3×8min @171-181W, 3min recovery @100W",
            "cooldown": "10min easy spin"
          },
          "coaching_notes": "First interval week — focus on holding power steady, not going out too hard. If you can't complete rep 3, reduce to 160W. NP should be ~170W."
        },
        {
          "id": "tue_strength",
          "day": "Tuesday",
          "sport": "strength",
          "type": "A",
          "duration_min": 52,
          "targets": {
            "exercises": [
              { "name": "KB Swing", "sets": 3, "reps": 12 },
              { "name": "Single-leg RDL", "sets": 3, "reps": 8, "per_side": true },
              { "name": "Goblet Squat", "sets": 3, "reps": 10 },
              { "name": "Suitcase Carry", "sets": 3, "reps": "20m", "per_side": true },
              { "name": "KB Row", "sets": 3, "reps": 10, "per_side": true }
            ],
            "mobility_min": 30,
            "mobility_focus": "Hip Complex"
          },
          "coaching_notes": "Rest 60-90s between sets. Swing: drive hips, not a squat. Single-leg RDL: hinge until hamstring tension, control is everything. Goblet: heels down, chest up. Carry: ribs down, no lateral lean. Row: full scapular retraction at top."
        },
        {
          "id": "wed_swim",
          "day": "Wednesday",
          "sport": "swim",
          "type": "technique",
          "duration_min": 50,
          "targets": {
            "total_distance_m": 1100,
            "warm_up": "200m easy",
            "drills": "4×50m (30s rest each): reps 1–2 catch-up drill (one arm fully extended before the other pulls), reps 3–4 fingertip drag (drag fingertips along water surface on recovery)",
            "main_set": {
              "css_target_sec_per_100m": null,
              "description": "4×150m @CSS+15s (~3:15/100m), 30s rest between"
            },
            "cool_down": "150m easy"
          },
          "coaching_notes": "Technique week — no threshold work. Catch-up drill trains full extension and timing. Fingertip drag trains high elbow recovery. The 150s should feel controlled and relaxed, not like CSS efforts."
        },
        {
          "id": "thu_strength",
          "day": "Thursday",
          "sport": "strength",
          "type": "B",
          "duration_min": 48,
          "targets": {
            "exercises": [
              { "name": "Turkish Get-Up", "sets": 2, "reps": 3, "per_side": true },
              { "name": "Bulgarian Split Squat", "sets": 3, "reps": 8, "per_side": true },
              { "name": "KB Clean", "sets": 3, "reps": 5, "per_side": true },
              { "name": "Dead Bug", "sets": 3, "reps": 8 },
              { "name": "Renegade Row", "sets": 3, "reps": 5, "per_side": true }
            ],
            "mobility_min": 30,
            "mobility_focus": "T-spine"
          },
          "coaching_notes": "TGU: slow and deliberate, 45-60s per rep. Split squat: front foot flat, torso upright. Clean: hip hike → elbow through → rack, not a bicep curl. Dead bug: low back flat to floor — non-negotiable. Renegade row: hips square, no rotation."
        },
        {
          "id": "sat_bike",
          "day": "Saturday",
          "sport": "bike",
          "type": "z2",
          "duration_min": 75,
          "targets": {
            "power_min": 100,
            "power_max": 125,
            "hr_max": 145,
            "warmup": null,
            "main_set": "75min steady Z2, flat to moderate route",
            "cooldown": null
          },
          "coaching_notes": "First brick of the block. Flat to moderate route, controlled HR. Focus on steady power, not speed."
        },
        {
          "id": "sat_run",
          "day": "Saturday",
          "sport": "run",
          "type": "easy",
          "duration_min": 30,
          "targets": {
            "pace_min_sec": 345,
            "pace_max_sec": 375,
            "hr_max": 145,
            "zone": "Z2"
          },
          "coaching_notes": "Run will feel heavy — that's normal. Don't chase pace, chase HR. If HR >150 at 5:45/km, slow down. Goal is adapting to the T2 transition."
