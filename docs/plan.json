          "id": "sun_swim",
          "day": "Sunday",
          "sport": "swim",
          "type": "easy",
          "duration_min": 30,
          "targets": {
            "total_distance_m": null,
            "main_set": {
              "css_target_sec_per_100m": null,
              "description": "30min easy — no watch pressure, focus on breathing and feel in water"
